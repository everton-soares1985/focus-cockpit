{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    },
    "sql:default",
    "sql:allow-execute"
  ]
}
