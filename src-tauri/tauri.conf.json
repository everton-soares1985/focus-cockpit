{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Cockpit",
  "version": "0.1.1",
  "identifier": "io.github.evertonsoares.focuscockpit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Cockpit",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:painel.sqlite3"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Everton Soares",
    "category": "Productivity",
    "shortDescription": "Painel pessoal local para foco, planejamento e organização.",
    "longDescription": "Aplicativo desktop offline para organizar foco semanal, projetos, plano de carreira, cursos, diplomas e atalhos de arquivos.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
